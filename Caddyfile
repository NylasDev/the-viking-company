# Caddy auto-provisions and renews Let's Encrypt TLS for these hostnames once
# their DNS A/AAAA records point at this server. Edit the domains if needed.
{
	email sergiuvataman.dev@gmail.com
}

thevikingcompany.eu, www.thevikingcompany.eu {
	root * /srv
	encode zstd gzip

	# static export: serve the file, its directory index, or the .html fallback
	try_files {path} {path}/ {path}.html /index.html
	file_server

	# long-cache the immutable Next.js build assets
	@assets path /_next/static/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	handle_errors {
		rewrite * /404.html
		file_server
	}
}
